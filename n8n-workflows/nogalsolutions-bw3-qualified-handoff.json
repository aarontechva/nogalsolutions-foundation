      "id": "bw3-node-06",
      "name": "Fetch HubSpot Pipeline Stages",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1552, 304],
      "credentials": {
        "httpHeaderAuth": {
          "id": "DdVdSVtCVZbUgwOD",
          "name": "HubSpot Private App Token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const pipelinesResponse = $('Fetch HubSpot Pipeline Stages').first().json;\nconst pipelines = pipelinesResponse.results;\nlet pipelineId = null;\nlet stageId = null;\n\nfor (const pipeline of pipelines) {\n  for (const stage of pipeline.stages) {\n    if (stage.label.toLowerCase() === 'qualified') {\n      pipelineId = pipeline.id;\n      stageId = stage.id;\n      break;\n    }\n  }\n  if (stageId) break;\n}\n\nif (!stageId) {\n  throw new Error(\"Could not find 'qualified' stage in any HubSpot deals pipeline. Verify pipeline stage labels in HubSpot.\");\n}\n\nreturn [{ json: { pipeline_id: pipelineId, stage_id: stageId } }];"
      },
      "id": "bw3-node-07",
      "name": "Extract Qualified Stage ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1808, 304]
    },
    {
      "parameters": {
        "jsCode": "const prospect = $('Call Sub-workflow').first().json;\nconst companyBody = $('Get Company from Supabase').first().json.body;\nconst company = (companyBody && companyBody.length > 0) ? companyBody[0] : null;\nconst stageData = $('Extract Qualified Stage ID').first().json;\n\nconst nameParts = (prospect.full_name || '').trim().split(' ');\nconst firstname = nameParts[0] || '';\nconst lastname = nameParts.slice(1).join(' ') || '';\n\nconst companyName = company ? company.name : 'Unknown Company';\nconst companyWebsite = (company && company.website) ? company.website : '';\n\nreturn [{ json: {\n  prospect_id: prospect.id,\n  email: prospect.email,\n  full_name: prospect.full_name,\n  firstname,\n  lastname,\n  company_name: companyName,\n  company_website: companyWebsite,\n  pipeline_id: stageData.pipeline_id,\n  stage_id: stageData.stage_id,\n  deal_name: companyName + ' — NogalSolutions Engagement'\n} }];"
      },
