      "parameters": {
        "jsCode": "const prospect = $('Call Sub-workflow').first().json;\nconst nameParts = (prospect.full_name || '').trim().split(' ');\nconst firstname = nameParts[0] || '';\nconst lastname = nameParts.slice(1).join(' ') || '';\nreturn [{ json: { email: prospect.email, firstname, lastname } }];"
      },
