    {
      "parameters": {
        "jsCode": "const contactResults = $('Fetch Deal-Contact Assoc Labels').first().json.results;\nconst companyResults = $('Fetch Deal-Company Assoc Labels').first().json.results;\n\nconst contactType = contactResults.find(r => r.category === 'HUBSPOT_DEFINED' && r.label === null)\n  || contactResults.find(r => r.category === 'HUBSPOT_DEFINED');\n\nconst companyType = companyResults.find(r => r.category === 'HUBSPOT_DEFINED' && r.label === null)\n  || companyResults.find(r => r.category === 'HUBSPOT_DEFINED');\n\nif (!contactType) throw new Error('Could not find HUBSPOT_DEFINED deal->contact association type from HubSpot labels API');\nif (!companyType) throw new Error('Could not find HUBSPOT_DEFINED deal->company association type from HubSpot labels API');\n\nreturn [{ json: {\n  deal_contact_type_id: contactType.typeId,\n  deal_company_type_id: companyType.typeId\n} }];"
      },
